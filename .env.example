# Copy this file to `.env` (gitignored) and pick ONE mode.

# ── Mode 1: zero-config demo (planted Viktor + Rajesh entities) ──────────────
# Stubbed GPU calls, no API key needed. The fastest way to see the pipeline
# work end-to-end. Documents are still validated and risk is still scored
# deterministically — only the three LLM calls are faked.
KYC_DEMO=1

# ── Mode 2: real LLMs via Groq + local fastembed embeddings ─────────────────
# Uncomment and provide a Groq API key from https://console.groq.com/keys.
# fastembed runs on CPU inside the container; embeddings are ONNX BGE-small.
# KYC_DEMO=0
# KYC_BACKEND=groq
# GROQ_API_KEY=gsk_replace_me

# ── Optional Groq tunables (sensible defaults if omitted) ───────────────────
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_REASON_MODEL=llama-3.3-70b-versatile
# KYC_LOCAL_EMBEDDER=BAAI/bge-small-en-v1.5

# ── Optional: slow the pipeline down for a watchable live demo ──────────────
# KYC_STEP_DELAY_MS=400
