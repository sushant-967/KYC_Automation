# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Node / JS
node_modules/
dist/
build/
.wrangler/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*
coverage/

# Python (for the ROCm side)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Claude Code — share settings.json + commands, keep personal/local settings out
.claude/settings.local.json

# Env / secrets — never commit
.env
.env.*
!.env.example
secrets/
*.pem
*.key

# Local SQLite state + ingested data (regenerated by ingest.py)
server/*.db
server/*.db-wal
server/*.db-shm
server/uploads/

# Large bundled datasets — add explicitly if needed
data/opensanctions/*.jsonl
data/opensanctions/*.json
data/opensanctions/*.csv
